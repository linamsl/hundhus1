---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sidan hittades inte – Hundhus1"
  description="Sidan du letar efter finns inte."
  canonicalPath="/404"
>
  <section class="section" style="margin-top: var(--header-height); min-height: 60vh; display: flex; align-items: center;">
    <div class="container" style="text-align: center;">
      <div class="section-header fade-up">
        <span class="label">404</span>
        <h1>Sidan hittades inte</h1>
        <p>Sidan du letar efter verkar ha sprungit iväg på promenad.</p>
      </div>
      <div class="fade-up">
        <a href="/" class="btn btn-primary">Tillbaka till startsidan</a>
      </div>
    </div>
  </section>
</BaseLayout>
