---
import BaseLayout from '../layouts/BaseLayout.astro';

const courses = [
  {
    title: "Valpkurs",
    description: "Skapa en trygg relation och balans med din hund. Fokus på lugn, vardagliga situationer och kommunikation mellan hund och människa.",
    tag: "Populär",
    tagClass: "popular"
  },
  {
    title: "Fortsättning / Unghund",
    description: "För dig som gått valp- eller grundkurs. Ledarskap, passivitet och hundspråk — nu med promenader och hundmöten.",
    tag: "Anmäl intresse",
    tagClass: "interest"
  },
  {
    title: "Promenadkurs",
    description: "Lär hundarna fungera i grupp, ta det lugnt och gå promenad tillsammans utan stress.",
    tag: "Datum släppta",
    tagClass: "open"
  },
  {
    title: "Apportering",
    description: "Grunderna i apportering för dig som vill starta på ett WT. Skott förekommer. Krav: inkallning och föremålsintresse.",
    tag: "Ny kurs",
    tagClass: "new"
  },
  {
    title: "Nose Work",
    description: "Passar alla raser oavsett ålder. Hunden jobbar med nosen och du lär dig läsa din hund. Fantastisk mental stimulans.",
    tag: "Anmäl intresse",
    tagClass: "interest"
  },
  {
    title: "Spår och sök",
    description: "Pröva på spår och sök — lär dig grunderna under 3 tillfällen utomhus (17:00–20:00).",
    tag: "Anmäl intresse",
    tagClass: "interest"
  },
  {
    title: "Klickerkurs",
    description: "Träna med positiv förstärkning. En helgkurs där du lär dig tajma in och förstärka beteenden i rätt sekund.",
    tag: "Anmäl intresse",
    tagClass: "interest"
  },
  {
    title: "Barn med hund",
    description: "En rolig kurs där barnen får gå en egen kurs med sin hund. Aktiviteter, skogspromenad och fika!",
    tag: "Anmäl intresse",
    tagClass: "interest"
  },
  {
    title: "Öppen träning",
    description: "Olika teman vid varje träff med fokus på vardagliga situationer. Föranmälan krävs.",
    tag: "Löpande",
    tagClass: "open"
  },
  {
    title: "Privatträning",
    description: "Skräddarsydd träning för dig med specifika önskemål eller utmaningar. Boka via kontaktformuläret.",
    tag: "På begäran",
    tagClass: "interest"
  }
];
---

<BaseLayout
  title="Hundkurser i Täby – Hundhus1"
  description="Hundkurser i Täby: valpkurs, lydnadskurs, nose work, apportering, klickerkurs och mer. Anmäl ditt intresse till Hundhus1."
  canonicalPath="/kurser"
>
  <section class="section" style="margin-top: var(--header-height);">
    <div class="container">
      <div class="section-header fade-up">
        <span class="label">Hundkurser</span>
        <h1>Kurser</h1>
        <p>Vi erbjuder kurser för alla nivåer — från valpkurs till avancerad jaktträning. Alla kurser hålls i Täby.</p>
      </div>

      <div class="courses-grid stagger">
        {courses.map((course, i) => (
          <div class="course-card fade-up" style={`--i: ${i % 3}`}>
            <span class={`course-tag ${course.tagClass}`}>{course.tag}</span>
            <h3>{course.title}</h3>
            <p>{course.description}</p>
          </div>
        ))}
      </div>

      <div class="fade-up" style="margin-top: 3rem; text-align: center;">
        <p style="margin-bottom: 0.5rem; font-weight: 600; font-family: var(--font-heading);">Intresserad? Anmäl via kontaktformuläret.</p>
        <p style="margin-bottom: 1.5rem; color: var(--color-text-light); font-size: 0.92rem;">Skriv vilken kurs ni är intresserade av i meddelandet.</p>
        <a href="/kontakt" class="btn btn-primary">Anmäl kursintresse</a>
      </div>

      <div class="notice-box fade-up">
        <h3>Kurspolicy</h3>
        <ul>
          <li>Kurs kan ställas in om färre än hälften av platserna är fyllda.</li>
          <li>Vid avbokning innan kursstart återbetalas avgiften vid uppvisande av läkar-/veterinärintyg.</li>
          <li>Vid inställd kurs återbetalas hela kursavgiften.</li>
          <li>Vid enstaka missade kurstillfällen sker ingen återbetalning.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
