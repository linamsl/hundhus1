---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Priser – Hundhus1 hunddagis i Täby"
  description="Priser för hunddagis på Hundhus1 i Täby. Heltid 3800 kr/månad, deltid från 3000 kr/månad. Öppet måndag–fredag."
  canonicalPath="/priser"
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">Priser – Hunddagis</h1>

      <div class="price-table">
        <div class="price-row header">
          <span>Dagisform</span>
          <span>Pris</span>
        </div>
        <div class="price-row">
          <span>Heltid (5 dagar/vecka)</span>
          <span class="price-amount">3 800 kr/mån</span>
        </div>
        <div class="price-row">
          <span>Deltid (3 dagar/vecka)</span>
          <span class="price-amount">3 300 kr/mån</span>
        </div>
        <div class="price-row">
          <span>Deltid (2 dagar/vecka)</span>
          <span class="price-amount">3 000 kr/mån</span>
        </div>
      </div>

      <p class="price-note">Särskild taxa för valpar och unghundar under 2 år samt hundar över 55 cm.</p>

      <h2 class="section-title" style="margin-top: 3rem;">Öppettider</h2>

      <div class="hours-grid">
        <div class="hours-row">
          <span>Måndag</span><span>07:00 – 18:00</span>
        </div>
        <div class="hours-row">
          <span>Tisdag</span><span>07:00 – 18:00</span>
        </div>
        <div class="hours-row">
          <span>Onsdag</span><span>07:00 – 18:00</span>
        </div>
        <div class="hours-row">
          <span>Torsdag</span><span>07:00 – 18:00</span>
        </div>
        <div class="hours-row">
          <span>Fredag</span><span>07:00 – 17:30</span>
        </div>
        <div class="hours-row">
          <span>Lördag–Söndag</span><span>Stängt</span>
        </div>
      </div>

      <p class="price-note">Semesterstängt: vecka 28–31 samt 7 dagar över jul/nyår.</p>

      <div style="text-align: center; margin-top: 2.5rem;">
        <p style="margin-bottom: 1rem; color: var(--color-text-light);">Företaget innehar F-skattsedel och är momsregistrerat.</p>
        <a href="/kontakt" class="btn">Anmäl intresse</a>
      </div>
    </div>
  </section>
</BaseLayout>
