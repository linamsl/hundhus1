---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = '' } = Astro.props;
const canonicalUrl = `https://www.hundhus1.se${canonicalPath}`;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Hundhus1" />
  <meta property="og:image" content="https://www.hundhus1.se/images/slideshow/slide1.jpg" />

  <!-- Structured Data: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Hundhus1 i Täby",
    "description": "Hunddagis i Täby Kyrkby med långa promenader, hundkurser och trygg hundgrupp.",
    "url": "https://www.hundhus1.se",
    "telephone": "+46707774248",
    "email": "info@hundhus1.se",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Holmgårdsvägen 5",
      "addressLocality": "Täby",
      "postalCode": "18774",
      "addressCountry": "SE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 59.4738,
      "longitude": 18.0686
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday"], "opens": "07:00", "closes": "18:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "07:00", "closes": "17:30" }
    ],
    "priceRange": "3000-3800 kr/månad",
    "image": "https://www.hundhus1.se/images/slideshow/slide1.jpg",
    "sameAs": []
  })} />

  <link rel="sitemap" href="/sitemap-index.xml" />

  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/images/logo.png" alt="Hundhus1 logotyp" width="60" height="60" />
      </a>
      <button class="nav-toggle" aria-label="Öppna meny" id="navToggle">
        <span></span><span></span><span></span>
      </button>
      <nav class="main-nav" id="mainNav">
        <ul>
          <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Välkommen</a></li>
          <li><a href="/om-oss" class={Astro.url.pathname === '/om-oss/' ? 'active' : ''}>Om oss</a></li>
          <li><a href="/priser" class={Astro.url.pathname === '/priser/' ? 'active' : ''}>Priser</a></li>
          <li><a href="/kurser" class={Astro.url.pathname === '/kurser/' ? 'active' : ''}>Kurser</a></li>
          <li><a href="/dagisbilder" class={Astro.url.pathname === '/dagisbilder/' ? 'active' : ''}>Dagisbilder</a></li>
          <li><a href="/kontakt" class={Astro.url.pathname === '/kontakt/' ? 'active' : ''}>Kontakt</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Hundhus1</h4>
          <p>Hunddagis i Täby Kyrkby med fokus på långa promenader, balans i hundgruppen och trygghet.</p>
        </div>
        <div class="footer-col">
          <h4>Sidor</h4>
          <a href="/om-oss">Om oss</a>
          <a href="/priser">Priser</a>
          <a href="/kurser">Kurser</a>
          <a href="/dagisbilder">Dagisbilder</a>
          <a href="/kontakt">Kontakt</a>
        </div>
        <div class="footer-col">
          <h4>Kontakt</h4>
          <p>Holmgårdsvägen 5<br>187 74 Täby</p>
          <p style="margin-top: 0.5rem;">Tel: <a href="tel:+46707774248">070-777 42 48</a></p>
          <p>E-post: <a href="mailto:info@hundhus1.se">info@hundhus1.se</a></p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Anela konsults Hundhus1 i Täby AB. Alla rättigheter förbehållna.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('navToggle');
    const nav = document.getElementById('mainNav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>
</body>
</html>
